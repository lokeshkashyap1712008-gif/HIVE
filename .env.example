# HIVE — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Qwen Cloud API key (REQUIRED — pay-as-you-go sk-..., NOT Token Plan sk-sp-...):
#   1. Sign up: https://qwencloud.com
#   2. Create key: https://home.qwencloud.com/api-keys
#   3. Paste below. Never commit .env.

# ══════════════════════════════════════════════
# LLM — Qwen Cloud (DashScope / Alibaba Cloud) — PRIMARY
# ══════════════════════════════════════════════
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_MODEL=qwen3.7-plus

# ══════════════════════════════════════════════
# LLM — Local (Ollama) — FALLBACK
# ══════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_LARGE_MODEL=qwen2.5:14b

# ══════════════════════════════════════════════
# System
# ══════════════════════════════════════════════
LOG_LEVEL=INFO
DEBUG=false
MAX_CONCURRENT_AGENTS=8
MEMORY_THRESHOLD_MB=2048
MIN_MEMORY_MB=500
HIVE_HOME=~/.hive

# ══════════════════════════════════════════════
# Browser Automation
# ══════════════════════════════════════════════
# After pip install: playwright install chromium
# Optional Chrome-profile automation: pip install browser-use
HIVE_SCREENSHOT_DIR=~/.hive/screenshots
HIVE_CHROME_PROFILE=~/.hive/chrome-automation
MINUTEMAIL_API_KEY=your_minutemail_key_here

# Drive your REAL installed Google Chrome instead of Playwright's bundled
# Chromium. Real Chrome has a genuine fingerprint, so hard sites (Spotify,
# Google) are far less likely to throw a bot challenge at login. Recommended
# for logging into protected consumer sites. Set to "chrome" to enable.
HIVE_BROWSER_CHANNEL=chromium

# NOTE on reusing an existing login: modern Chrome (127+) encrypts cookies with
# "app-bound encryption" (v20), so copying your existing Chrome profile does NOT
# carry over logins, and Google blocks automating your default profile directly.
# The working approach: set HIVE_BROWSER_CHANNEL=chrome and log into the site
# ONCE inside HIVE's browser — it then stays logged in on future runs.
HIVE_CHROME_PROFILE_REUSE=false
HIVE_CHROME_SOURCE_PROFILE=Default
# HIVE_CHROME_USER_DATA_DIR=   # auto-detected; set only to override

# ══════════════════════════════════════════════
# Personal Email Inbox (auto-read verification codes via IMAP)
# ══════════════════════════════════════════════
# Lets HIVE read OTP/verification codes from YOUR inbox during login/signup.
# IMPORTANT: use an APP PASSWORD, not your normal password.
#   Gmail:   https://myaccount.google.com/apppasswords  (requires 2FA enabled)
#   Outlook: https://account.live.com/proofs/AppPassword
# Host/port are auto-detected for gmail/outlook/yahoo/icloud.
# Prefer storing in the vault instead: vault_store_credential(site='imap', ...)
# HIVE_IMAP_USER=you@gmail.com
# HIVE_IMAP_PASSWORD=your_app_password
# HIVE_IMAP_HOST=
# HIVE_IMAP_PORT=993

# ══════════════════════════════════════════════
# Vault (encrypted credential & card storage)
# ══════════════════════════════════════════════
# Optional master password (otherwise uses OS keyring)
# HIVE_VAULT_MASTER_PASSWORD=your_master_password

# ══════════════════════════════════════════════
# Checkout / Payments Guardrails
# ══════════════════════════════════════════════
HIVE_CHECKOUT_AUTONOMOUS=false
HIVE_MAX_ORDER_AMOUNT=500
HIVE_MAX_DAILY_SPEND=1000
# Comma-separated allowed merchant domains (empty = allow all)
HIVE_CHECKOUT_ALLOWED_MERCHANTS=amazon.com,shopify.com

# ══════════════════════════════════════════════
# OAuth (GitHub / Google)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
HIVE_OAUTH_PORT=8765
# ══════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_token_here
STRIPE_API_KEY=sk_live_your_key_here
SENDGRID_API_KEY=SG.your_key_here
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
