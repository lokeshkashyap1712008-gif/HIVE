# ===== HIVE CONFIGURATION =====

# ===== LLM PROVIDER =====
# If DASHSCOPE_API_KEY is set: use Qwen Cloud (DashScope)
# If not set: fall back to local Ollama (auto-switch)
DASHSCOPE_API_KEY=

# ===== LOCAL OLLAMA =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_LARGE_MODEL=qwen2.5:14b

# ===== SYSTEM =====
LOG_LEVEL=INFO
DEBUG=false
MAX_CONCURRENT_AGENTS=8
MEMORY_THRESHOLD_MB=2048
MIN_MEMORY_MB=500

# ===== INTEGRATIONS (optional) =====
GITHUB_TOKEN=