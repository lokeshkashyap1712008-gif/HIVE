# HIVE — Environment Variables
# Copy this to .env and fill in your values

# ══════════════════════════════════════════════
# LLM — Qwen Cloud (DashScope) — PRIMARY
# ══════════════════════════════════════════════
# Get your key at: https://dashscope.console.aliyun.com/ → API Keys
# With DashScope: set DASHSCOPE_API_KEY and leave OLLAMA vars as fallback
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# ══════════════════════════════════════════════
# LLM — Local (Ollama) — FALLBACK
# ══════════════════════════════════════════════
# Used when DASHSCOPE_API_KEY is not set
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_LARGE_MODEL=qwen2.5:14b

# ══════════════════════════════════════════════
# System
# ══════════════════════════════════════════════
LOG_LEVEL=INFO
DEBUG=false
MAX_CONCURRENT_AGENTS=8
MEMORY_THRESHOLD_MB=2048
MIN_MEMORY_MB=500

# ══════════════════════════════════════════════
# Integrations (optional)
# ══════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_token_here
STRIPE_API_KEY=sk_live_your_key_here
SENDGRID_API_KEY=SG.your_key_here