# HIVE — Environment Variables
# Copy this to .env and fill in your values

# ══════════════════════════════════════════════
# LLM — Qwen Cloud (DashScope) — PRIMARY
# ══════════════════════════════════════════════
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_MODEL=qwen-max

# ══════════════════════════════════════════════
# LLM — Local (Ollama) — FALLBACK
# ══════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_LARGE_MODEL=qwen2.5:14b

# ══════════════════════════════════════════════
# System
# ══════════════════════════════════════════════
LOG_LEVEL=INFO
DEBUG=false
MAX_CONCURRENT_AGENTS=8
MEMORY_THRESHOLD_MB=2048
MIN_MEMORY_MB=500
HIVE_HOME=~/.hive

# ══════════════════════════════════════════════
# Browser Automation
# ══════════════════════════════════════════════
# After pip install: playwright install chromium
# Optional Chrome-profile automation: pip install browser-use
HIVE_SCREENSHOT_DIR=~/.hive/screenshots
HIVE_CHROME_PROFILE=~/.hive/chrome-automation
MINUTEMAIL_API_KEY=your_minutemail_key_here

# ══════════════════════════════════════════════
# Vault (encrypted credential & card storage)
# ══════════════════════════════════════════════
# Optional master password (otherwise uses OS keyring)
# HIVE_VAULT_MASTER_PASSWORD=your_master_password

# ══════════════════════════════════════════════
# Checkout / Payments Guardrails
# ══════════════════════════════════════════════
HIVE_CHECKOUT_AUTONOMOUS=false
HIVE_MAX_ORDER_AMOUNT=500
HIVE_MAX_DAILY_SPEND=1000
# Comma-separated allowed merchant domains (empty = allow all)
HIVE_CHECKOUT_ALLOWED_MERCHANTS=amazon.com,shopify.com

# ══════════════════════════════════════════════
# OAuth (GitHub / Google)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
HIVE_OAUTH_PORT=8765
# ══════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_token_here
STRIPE_API_KEY=sk_live_your_key_here
SENDGRID_API_KEY=SG.your_key_here
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
